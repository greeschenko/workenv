#!/bin/sh
# Brightness: display icon + percentage

BL_PATH="/sys/class/backlight/amdgpu_bl1"

brightness=$(cat "$BL_PATH/brightness" 2>/dev/null)
max_brightness=$(cat "$BL_PATH/max_brightness" 2>/dev/null)

if [ -z "$brightness" ] || [ -z "$max_brightness" ] || [ "$max_brightness" -eq 0 ]; then
    exit 1
fi

percent=$((brightness * 100 / max_brightness))

icon="茶찊"

pct=$(printf "%3d" "$percent")
echo "$icon $pct%"
