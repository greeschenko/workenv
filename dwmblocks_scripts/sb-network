#!/bin/sh
# Network: WiFi signal + Bluetooth status

wifi_icon="箚뼧"
wifi_signal="  0"

if ip link show wlan0 2>/dev/null | grep -q "state UP"; then
    signal=$(cat /proc/net/wireless 2>/dev/null | grep wlan0 | awk '{gsub(/-/,""); print int($4)}')
    if [ -n "$signal" ] && [ "$signal" -gt 0 ]; then
        wifi_icon="箚뼦"
        wifi_signal=$(printf "%3d" "$signal")
    fi
fi

bt_icon="箚궟"
if rfkill list bluetooth 2>/dev/null | grep -q "Soft blocked: no"; then
    bt_icon="箚궚"
    if bluetoothctl devices Connected 2>/dev/null | grep -q "Device"; then
        bt_icon="箚궞"
    fi
fi

echo "$wifi_icon $wifi_signal $bt_icon"