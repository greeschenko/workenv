#!/bin/sh
# Sound: speaker icon + volume percentage

get_volume() {
    pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null | grep -o '[0-9]*%' | head -1 | tr -d '%'
}

get_mute() {
    pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null | grep -o 'yes\|no'
}

mute=$(get_mute)
volume=$(get_volume)

if [ "$mute" = "yes" ] || [ -z "$volume" ]; then
    icon="箚씇"
    volume=0
elif [ "$volume" -eq 0 ]; then
    icon="箚뻶"
else
    icon="箚빢"
fi

pct=$(printf "%3d" "$volume")
echo "$icon $pct%"
